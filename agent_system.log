{
    "action": "write",
    "filename": "main.py",
    "code": "import time\nimport os\nimport sys\nimport psutil\nimport threading\nimport select\nfrom dashboard.utils.gpu_monitor import get_gpu_temperature\nfrom dashboard.utils.cpu_monitor import get_cpu_stats\nfrom agents.base_agent import my_agent \n\nGREEN, YELLOW, RED = \"\\033[92m\", \"\\033[93m\", \"\\033[91m\"\nRESET, BOLD, CYAN = \"\\033[0m\", \"\\033[1m\", \"\\033[96m\"\n\nfull_response = \"System Stabilized. Waiting for input...\"\nis_thinking = False\nscroll_pos = 0\n\ndef background_ai_task(prompt):\n    global full_response, is_thinking, scroll_pos\n    is_thinking = True\n    full_response = my_agent.ask_ai(prompt)\n    scroll_pos = 0\n    is_thinking = False\n\ndef get_color(value, warn=70, crit=85):\n    try:\n        val = float(value)\n        if val >= crit: return RED + BOLD\n        if val >= warn: return YELLOW\n        return GREEN\n    except: return RESET\n\ndef run_dashboard():\n    global scroll_pos\n    os.system('clear')\n    \n    pipe_path = os.path.expanduser(\"~/my-ai-agents/cmd_pipe\")\n    if not os.path.exists(pipe_path):\n        os.mkfifo(pipe_path)\n    \n    pipe_fd = os.open(pipe_path, os.O_RDONLY | os.O_NONBLOCK)\n\n    # Initialize stats\n    last_sensor_update = 0\n    gpu_t, cpu_u, cpu_t, ram_u, mem_count = 0, 0, 0, 0, 0\n\n    try:\n        while True:\n            sys.stdout.write(\"\\033[H\")\n            current_time = time.time()\n\n            # GATE: Only touch files/sensors once per second\n            if current_time - last_sensor_update > 1.0:\n                gpu_t = get_gpu_temperature()\n                cpu_u, cpu_t = get_cpu_stats()\n                ram_u = psutil.virtual_memory().percent\n                mem_count = my_agent.memory.get_count() # Moved INSIDE the gate!\n                last_sensor_update = current_time\n            \n            # Check pipe for new commands\n            ready, _, _ = select.select([pipe_fd], [], [], 0)\n            if ready and not is_thinking:\n                user_input = os.read(pipe_fd, 1024).decode().strip()\n                if user_input:\n                    thread = threading.Thread(target=background_ai_task, args=(user_input,))\n                    thread.daemon = True\n                    thread.start()\n\n            # Smooth Scroll Logic\n            display_text = str(full_response).replace(\"\\n\", \" \")\n            if len(display_text) > 30:\n                padded = display_text + \"   |   \"\n                start = int(scroll_pos) % len(padded)\n                scroll_window = (padded + padded)[start:start+30]\n                scroll_pos += 1\n            else:\n                scroll_window = display_text.ljust(30)\n\n            raw_status = \"Thinking...\" if is_thinking else \"Idle\"\n            status_color = YELLOW if is_thinking else GREEN\n            status_padding = \" \" * (18 - len(raw_status))\n\n            output = [\n                f\"{BOLD}╔\" + \"═\" * 32 + \"╗\",\n                f\"║    {CYAN}AI AGENT SYSTEM MONITOR{RESET}{BOLD}     ║\",\n                f\"╠\" + \"═\" * 32 + \"╣\",\n                f\"║ CPU Usage:      {get_color(cpu_u, 90, 98)}{cpu_u:>7}%{RESET}{BOLD} ║\",\n                f\"║ CPU Temp:       {get_color(cpu_t, 75, 85)}{cpu_t:>7}°C{RESET}{BOLD} ║\",\n                f\"║ RAM Usage:      {get_color(ram_u, 80, 95)}{ram_u:>7}%{RESET}{BOLD} ║\",\n                f\"║ GPU Temp:       {get_color(gpu_t, 75, 85)}{str(gpu_t):>7}°C{RESET}{BOLD} ║\",\n                f\"╠\" + \"═\" * 32 + \"╣\",\n                f\"║ {CYAN}MEMORIES SAVED:{RESET}{BOLD} {mem_count:>14} ║\",\n                f\"║ {CYAN}AGENT STATUS:{RESET}{BOLD}  {status_color}{raw_status}{RESET}{BOLD}{status_padding}║\",\n                f\"╟\" + \"─\" * 32 + \"╢\",\n                f\"║ {CYAN}LAST RESPONSE:{RESET}{BOLD}                 ║\",\n                f\"║ {scroll_window:<30} ║\",\n                f\"╚\" + \"═\" * 32 + f\"╝{RESET}\",\n                f\"\\n {CYAN}System Active (10 FPS Scroll){RESET} \"\n            ]\n            \n            sys.stdout.write(\"\\n\".join(output) + \"\\n\")\n            sys.stdout.flush()\n            time.sleep(0.1) \n        except KeyboardInterrupt:\n            os.close(pipe_fd)\n            print(f\"\\n\\n{YELLOW}[!] Dashboard Offline.{RESET}\")\n\nif __name__ == \"__main__\":\n    run_dashboard()",
    "thought": "Adding a docstring to main.py will provide documentation for the module, explaining its purpose and functionality."
}
