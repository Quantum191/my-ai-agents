  "code": "# Import necessary libraries\nimport requests\nfrom bs4 import BeautifulSoup\n\n# Function to get the current weather in Tokyo\ndef get_weather_tokyo():\n    url = 'https://www.weather-forecast.com/locations/Tokyo/Japan/forecasts/latest'\n    response = requests.get(url)\n    soup = BeautifulSoup(response.text, 'html.parser')\n    weather_info = soup.find('div', {'class': 'CurrentConditions--phraseValue--2xXSr'}).text\n    return weather_info\n\n# Call the function and print the result\ntokyo_weather = get_weather_tokyo()\nprint(f'The current weather in Tokyo is: {tokyo_weather}')"
}
